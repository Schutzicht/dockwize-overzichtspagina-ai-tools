---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Dockwize Toolkit',
  description = 'Alle tools en projecten die we voor Dockwize bouwden, op één plek.',
} = Astro.props;
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,400;0,500;0,700;0,900;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <slot />
  </body>
</html>
